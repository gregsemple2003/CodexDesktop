{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gregs.codex.local/orchestration/audit-result.schema.json",
  "title": "Audit Result",
  "description": "Machine-readable result of an audit gate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "pass_id",
    "transition_target",
    "verdict",
    "blocking_findings",
    "non_blocking_findings",
    "missing_evidence",
    "open_questions",
    "evidence_reviewed",
    "suggested_next_step",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "task_id": {
      "type": "string",
      "pattern": "^Task-\\d{4}$"
    },
    "pass_id": {
      "type": "string",
      "pattern": "^PASS-\\d{4}$"
    },
    "transition_target": {
      "enum": [
        "pass_closeout",
        "commit",
        "push",
        "handoff",
        "task_closure"
      ]
    },
    "verdict": {
      "enum": [
        "ready",
        "ready_with_caveats",
        "not_ready"
      ]
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "non_blocking_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_reviewed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_next_step": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "why_it_matters",
        "file_refs"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "why_it_matters": {
          "type": "string"
        },
        "file_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
